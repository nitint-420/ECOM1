{
  "name": "grocery-ecom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "postinstall": "cd packages/database && npx prisma generate",
    "db:generate": "pnpm --filter @ecom/database db:generate",
    "db:push": "pnpm --filter @ecom/database db:push",
    "db:seed": "pnpm --filter @ecom/database seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "next@>=14.0.0 <14.2.10": ">=14.2.10",
      "next@>=10.0.0 <14.2.7": ">=14.2.7",
      "next@>=14.0.0 <14.2.21": ">=14.2.21",
      "next@>=13.0 <14.2.30": ">=14.2.30",
      "next@>=0.9.9 <14.2.31": ">=14.2.31",
      "next@>=9.5.5 <14.2.15": ">=14.2.15",
      "next@>=0.9.9 <14.2.32": ">=14.2.32",
      "next@>=0.9.9 <14.2.24": ">=14.2.24",
      "next@>=13.3.0 <14.2.34": ">=14.2.34",
      "next@>=13.3.1-canary.0 <14.2.35": ">=14.2.35",
      "next@>=10.0.0 <15.5.10": ">=15.5.10",
      "next@>=13.0.0 <15.0.8": ">=15.0.8",
      "next@>=14.0.0 <14.2.25": ">=14.2.25",
      "next@>=9.5.0 <15.5.13": ">=15.5.13",
      "next@>=10.0.0 <15.5.14": ">=15.5.14",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}