{
  "name": "grocery-ecom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "postinstall": "cd packages/database && npx prisma generate",
    "db:generate": "pnpm --filter @ecom/database db:generate",
    "db:push": "pnpm --filter @ecom/database db:push",
    "db:seed": "pnpm --filter @ecom/database seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}